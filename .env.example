# WanderBuddy — Environment Variables
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=change-me-to-a-long-random-secret
FLASK_ENV=development
ADMIN_EMAIL=admin@travelandtrouble.com

# Database (default: SQLite in project root)
DATABASE_URL=wanderbuddy.db

# Razorpay (leave as-is for simulation mode)
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me_secret

# Flask-Mail (optional — for password reset emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=WanderBuddy <your@gmail.com>
