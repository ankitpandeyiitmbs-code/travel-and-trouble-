# WanderBuddy - Environment Configuration
# Copy this file to .env and fill in your values before deploying.

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE=wanderbuddy.db

# ── Admin ────────────────────────────────────────────────────────────────────
# The email address used to log in as admin
ADMIN_EMAIL=admin@example.com

# The plain-text password for the admin backdoor login (set a strong value!)
ADMIN_PASSWORD=change-this-admin-password

# ── Application URL ───────────────────────────────────────────────────────────
APP_URL=https://your-domain.com

# ── Razorpay Payment Gateway ──────────────────────────────────────────────────
# Get these from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Email (for password reset) ────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
# Use a Gmail App Password, not your real password
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@your-domain.com
